    STA     (EFFECT_REC),Y
    INY
    LDA     (EFFECT_REC),Y
    ADC     NUM_VALUE+1
    STA     (EFFECT_REC),Y
    JMP     .aftermath
.subtract:
    LDY     #$0D
    SEC
    LDA     (EFFECT_REC),Y
    SBC     NUM_VALUE
    STA     (EFFECT_REC),Y
    INY
    LDA     (EFFECT_REC),Y
    SBC     NUM_VALUE+1
    STA     (EFFECT_REC),Y
.aftermath:
    LDY     #$05
