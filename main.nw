    CMP     #$01
    BEQ     .one_threat
    JMP     END_TURN
.one_threat:
    JMP     MOVE_LOOP
.hostile:
    JSR     FIRST_GROUP_MEMBER
.walk_group:
    LDA     MOB_PTR+1
    BEQ     .group_done
