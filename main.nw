<<calc combat strength>>=
    ORG     $16E0
    SUBROUTINE
; Calculates combat strength using RANDOM_IN_RANGE
CALC_COMBAT_STRENGTH:
    LDA     IS_PLAYER_TURN
    CMP     #$01
    BEQ     .use_y7
    LDY     #$03
    LDA     (MOB_PTR),Y
    CMP     (ENTITY_PTR),Y
    BNE     .use_y7
    LDY     #$09
    BNE     .got_y
.use_y7:
    LDY     #$07
.got_y:
    TYA
    PHA
    LDA     (ENTITY_PTR),Y
    AND     #$0F
    TAX
    JSR     RANDOM_IN_RANGE
    STA     COMBAT_STRENGTH
    TXA
    JSR     RANDOM_IN_RANGE
    SEC
    ADC     COMBAT_STRENGTH
    STA     COMBAT_STRENGTH
    LDA     CHAR_AI_MODE
    BEQ     .check_5a74
.exit_pla:                     ; $1712 - reused by backward BNE from $1717
    PLA
    RTS
.check_5a74:
    LDA     IS_PLAYER_TURN
    BNE     .exit_pla
    PLA
    TAY
    TAX
    LDA     (ENTITY_PTR),Y
    AND     #$80
    BNE     .use_50
    LDA     #$0D
    BNE     .do_random
.use_50:
    LDA     #$50
.do_random:
    JSR     RANDOM_IN_RANGE
    CMP     #$00
    BEQ     .missed
    RTS
.missed:
    TXA
    TAY
    LDA     #$81
    STA     (ENTITY_PTR),Y
    JSR     SET_CURSOR_ROW21
    LDA     #$01
    JSR     SCENE_LOOP
    LDA     #$0A
    JSR     RANDOM_IN_RANGE
    SEC
    ADC     COMBAT_STRENGTH
    CMP     #$1F
    BCC     .cap_ok
    LDA     #$1F
.cap_ok:
    STA     COMBAT_STRENGTH
    RTS
@ %def CALC_COMBAT_STRENGTH

