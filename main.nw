    HEX 01              ; enable (patched: UNDER_LEVEL)
    HEX 570301
    HEX 03077F7BC61B
.rec5:                  ; record 5 ($60A9)
    HEX 01140706
    HEX 0102457D8C61
.rec6:                  ; record 6 ($60B3) - rest option
.rec6_enable = *
