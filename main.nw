    MOVB    CURRENT_ROW,TURN_START_ROW
    JSR     $1C6B           ; setup (unknown)
    STOB    #$14,WAIT_LOOP_COUNT
    JSR     $0DA4           ; unknown
    JMP     $1EC5           ; unknown (return path?)

; Threat assessment
