<<select combat target>>=
    ORG     $18E4
    SUBROUTINE
; Selects combat target based on CHAR_AI_MODE (3 paths: <3, 3-4, >=5)
SELECT_COMBAT_TARGET:
    LDA     CHAR_AI_MODE
    CMP     #$03
    BMI     .path_low
    CMP     #$05
    BMI     .path_mid
    JSR     FIRST_GROUP_MEMBER
    LDA     #$00
    STA     BEST_THREAT
.loop_high:
    JSR     GET_ENTITY_THREAT
    CMP     #$00
    BEQ     .skip_high
    LDY     #$05
    LDA     (MOB_PTR),Y
    AND     #$1F
    CMP     BEST_THREAT
    BMI     .skip_high
    STA     BEST_THREAT
    LDA     MOB_PTR
    STA     TARGET_PTR_LO
    LDA     MOB_PTR+1
    STA     TARGET_PTR_HI
.skip_high:
    JSR     NEXT_GROUP_MEMBER
    LDA     #$00
    CMP     MOB_PTR+1
    BNE     .loop_high
    CMP     BEST_THREAT
    BEQ     .path_low
    LDA     #$01
    RTS
.path_low:
    LDA     #$00
    CMP     STEPS_TAKEN
    BNE     .ret_2
    LDY     #$03
    LDA     (ENTITY_PTR),Y
    JSR     CHECK_ENCOUNTER
    LDA     #$02
    CMP     ENCOUNTER_RESULT
    BEQ     .ret_2
    JSR     CHECK_THREATS_HERE
    CMP     #$01
    BNE     .ret_2
    LDA     #$04
    RTS
.ret_2:
    LDA     #$02
    RTS
.path_mid:
    LDA     #$00
    STA     BEST_THREAT
    JSR     FIRST_GROUP_MEMBER
.loop_mid:
    JSR     GET_ENTITY_THREAT
    CMP     BEST_THREAT
    BEQ     .skip_mid
    BMI     .skip_mid
    STA     BEST_THREAT
    LDA     MOB_PTR
    STA     TARGET_PTR_LO
    LDA     MOB_PTR+1
    STA     TARGET_PTR_HI
.skip_mid:
    JSR     NEXT_GROUP_MEMBER
    LDA     #$00
    CMP     MOB_PTR+1
    BNE     .loop_mid
    CMP     BEST_THREAT
    BEQ     .path_low
    LDA     #$01
    RTS
