    ROL
    ROL
    ROL
    AND     #$F8
    STA     $5A7E
    LDY     #$0C
    LDA     (EFFECT_REC),Y
    PHA
    AND     #$0F
    TAX
    PLA
    ROR
    ROR
    ROR
    ROR
    AND     #$0F
    TAY
.decy:
    DEY
    BMI     .done_cnt
    INX
    BPL     .decy
.done_cnt:
    INY
    STY     STAT_LEVEL_BITS
    STY     $BA
    STY     $BB
.outer_loop:
    LDY     #$0E
    CPX     #$00
    BEQ     .store_final
    CLC
    LDA     $BA
    ADC     $5A7E
    STA     $BA
    BCC     .no_carry
    INC     $BB
.no_carry:
    LDA     (EFFECT_REC),Y
    CMP     $BB
    BCC     .store_final
    BNE     .next_iter
    DEY
    LDA     (EFFECT_REC),Y
    CMP     $BA
    BCC     .store_final
.next_iter:
    DEX
    CLC
    LDA     STAT_LEVEL_BITS
    ADC     #$10
    STA     STAT_LEVEL_BITS
    BNE     .outer_loop
.store_final:
    TXA
    ORA     STAT_LEVEL_BITS
