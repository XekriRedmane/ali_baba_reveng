    JSR     COMMIT_MOVE
    LDY     #$03
    LDA     (ENTITY_PTR),Y
    JSR     CHECK_ENCOUNTER
    LDA     ENCOUNTER_RESULT
    CMP     #$02
    BPL     .hostile
