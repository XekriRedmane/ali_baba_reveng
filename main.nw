\section{Character stats display}

[[DISPLAY_CHAR_STATS]] formats and displays the statistics of the
character whose record is pointed to by [[ENTITY_PTR]] ([[$F8/$F9]]).
It reads eight fields from the entity record, converts each to decimal
via [[NUM_TO_DECIMAL]], and writes the digits into a pre-formatted
string template at [[$7D83]].  After displaying the stats, it waits for
a keypress (or joystick button if [[INPUT_MODE]] is nonzero), then
exits via [[CLEAR_MAP]].

\begin{itemize}
  \item Field 6, bits 5--0: life force (max 63)
  \item Field 8, bits 3--0: group member count
  \item Field 7, bits 3--0: plus 1 = weapons
  \item Field 9, bits 3--0: plus 1 = ducats (gold)
  \item Field 5, bits 4--0: strength (max 31)
  \item Field 12, bits 3--0: sword rating
  \item Field 11, bits 4--0: level/armor
  \item Fields 13--14: 16-bit dagger/experience value
\end{itemize}

The routine first clears the digit positions in the template string by
writing spaces ([[$A0]]), then fills them via [[NUM_TO_DECIMAL]].  After
a cosmetic fix (suppressing a leading ``0'' in the experience field), it
scrolls the status line, prints the formatted stats, and enters an
input wait loop.

<<display char stats>>=
    ORG     $7780
DISPLAY_CHAR_STATS:
    SUBROUTINE DISPLAY_CHAR_STATS

    ; --- Clear digit positions in the stats template ---
    LDA     #$A0              ; space (high-bit ASCII)
    STA     STATS_LIFE        ; life force digits
    STA     STATS_DUCATS      ; \
    STA     STATS_DUCATS+1    ;  | ducats digits
    STA     STATS_DUCATS+2    ; /
    STA     STATS_SWORD       ; sword digits
    STA     STATS_DAGGR       ; dagger digits
    STA     STATS_STR         ; strength digits
    STA     STATS_SPEED       ; speed digits
    STA     STATS_DEXT        ; dexterity digits

    ; --- Format life force: field 6, bits 5-0 ---
    LDA     #$00
    STA     NUM_VALUE+1                ; high byte = 0
    LDY     #$06
    LDA     (ENTITY_PTR),Y            ; field 6
    AND     #$3F                       ; bits 5-0 = life force
    STA     NUM_VALUE
    STOW    STATS_LIFE_OUT,DECIMAL_OUT_PTR
    JSR     NUM_TO_DECIMAL

    ; --- Format group count: field 8, bits 3-0 ---
    LDY     #$08
    LDA     (ENTITY_PTR),Y            ; field 8
    AND     #$0F                       ; bits 3-0 = group count
    STA     NUM_VALUE
    STOW    STATS_WEAP_OUT,DECIMAL_OUT_PTR
    JSR     NUM_TO_DECIMAL

    ; --- Format weapons: field 7, bits 3-0, plus 1 ---
    LDY     #$07
    LDA     (ENTITY_PTR),Y            ; field 7
    AND     #$0F                       ; bits 3-0
    CLC
    ADC     #$01                       ; +1
    STA     NUM_VALUE
    STOW    STATS_SWORD_OUT,DECIMAL_OUT_PTR
    JSR     NUM_TO_DECIMAL

    ; --- Format ducats: field 9, bits 3-0, plus 1 ---
    LDY     #$09
    LDA     (ENTITY_PTR),Y            ; field 9
    AND     #$0F                       ; bits 3-0
    CLC
    ADC     #$01                       ; +1
    STA     NUM_VALUE
    STOW    STATS_DAGGR_OUT,DECIMAL_OUT_PTR
    JSR     NUM_TO_DECIMAL

    ; --- Format strength: field 5, bits 4-0 ---
    LDY     #$05
    LDA     (ENTITY_PTR),Y            ; field 5
    AND     #$1F                       ; bits 4-0 = strength
    STA     NUM_VALUE
    STOW    STATS_STR_OUT,DECIMAL_OUT_PTR
    JSR     NUM_TO_DECIMAL

    ; --- Format armor: field 12, bits 3-0 ---
    LDY     #$0C
    LDA     (ENTITY_PTR),Y            ; field 12
    AND     #$0F                       ; bits 3-0
    STA     NUM_VALUE
    STOW    STATS_SPEED_OUT,DECIMAL_OUT_PTR
    JSR     NUM_TO_DECIMAL

    ; --- Format dexterity: field 11, bits 4-0 ---
    LDY     #$0B
    LDA     (ENTITY_PTR),Y            ; field 11
    AND     #$1F                       ; bits 4-0 = dexterity
    STA     NUM_VALUE
    STOW    STATS_DEXT_OUT,DECIMAL_OUT_PTR
    JSR     NUM_TO_DECIMAL

    ; --- Format experience: fields 13-14 (16-bit) ---
    LDY     #$0D
    LDA     (ENTITY_PTR),Y            ; field 13 (low byte)
    STA     NUM_VALUE
    INY
    LDA     (ENTITY_PTR),Y            ; field 14 (high byte)
    STA     NUM_VALUE+1
    STOW    STATS_DUCATS_OUT,DECIMAL_OUT_PTR
    JSR     NUM_TO_DECIMAL

    ; --- Cosmetic: if hundreds digit is blank and tens is "0", blank it ---
    LDA     STATS_DUCATS+2    ; hundreds digit
    CMP     #$A0              ; blank (leading-zero suppressed)?
    BNE     .show             ; no -> 3+ digits, show as-is
    LDA     STATS_DUCATS+3    ; tens digit
    CMP     #$B0              ; "0"?
    BNE     .show             ; no -> show as-is
    LDA     #$A0              ; replace "0" with blank
    STA     STATS_DUCATS+3

    ; --- Display the stats ---
.show:
    JSR     SCROLL_STATUS_LINE
    JSR     PRINT_CTRL_AB              ; save cursor state
    LDA     #$15                       ; \  cursor to column 21,
    STA     $25                        ;  | row 0 (right half of
    LDA     #$00                       ;  | screen)
    STA     $24                        ; /
    LDA     #<STATS_TEMPLATE           ; \ print the stats template
    STA     PRINT_STRING_ADDR          ;  | string at $7D83
    LDA     #>STATS_TEMPLATE           ;  |
    STA     PRINT_STRING_ADDR+1        ; /
    JSR     PRINT_STRING               ; display stats
    LDA     #$14                       ; \  cursor to column 20,
    STA     $25                        ;  | row 0
    LDA     #$00                       ;  |
    STA     $24                        ; /

    ; --- Show input prompt based on mode ---
    LDA     INPUT_MODE
    BEQ     .keyboard                  ; 0 = keyboard mode
    LDX     #$18                       ; \ joystick: "PUSH BUTTON
    LDY     #$7E                       ; / TO GO ON" at $7E18
    BNE     .print_prompt
.keyboard:
    LDX     #$01                       ; \ keyboard: "PRESS M TO
    LDY     #$7E                       ; / CONTINUE" at $7E01
.print_prompt:
    JSR     PRINT_STRING_AT_ADDR       ; print prompt
    JSR     ANIM_TICK_AND_WAIT         ; tick animation + wait

    ; --- Wait for input ---
    STA     $C010                      ; clear keyboard strobe
.wait_key:
    LDA     $C000                      ; read keyboard
    BMI     .done                      ; key pressed -> exit
    LDA     INPUT_MODE
    BEQ     .wait_key                  ; keyboard mode -> loop
    LDX     #$00
    LDA     $C061,X                    ; read joystick button 0
    BMI     .done                      ; pressed -> exit
    INX
    LDA     $C061,X                    ; read joystick button 1
    BPL     .wait_key                  ; not pressed -> loop
.done:
    JMP     CLEAR_MAP                  ; exit via CLEAR_MAP
@ %def DISPLAY_CHAR_STATS

@ The stats template string at [[STATS_TEMPLATE]] ([[$7D83]]) contains
the formatted display layout with placeholder digits that
[[NUM_TO_DECIMAL]] overwrites at runtime.


