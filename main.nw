MODIFY_CHAR_STATS:
    SUBROUTINE
    ; Add or subtract gold from char record at (EFFECT_REC).
    ; Y=0: subtract NUM_VALUE/NUM_VALUE+1 from field 13/14
    ; Y≠0: add NUM_VALUE/NUM_VALUE+1 to field 13/14
