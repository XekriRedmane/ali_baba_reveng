    JMP     PRINT_STRING_AT_ADDR
@ %def INIT_GAME_DISPLAY
@ [[DRAW_BORDER_CHAR]] is a helper for [[INIT_GAME_DISPLAY]].  It draws a
2$\times$2 font character from charset~2 at column~[[X]], row~3.  The
character number is passed in~A.  It stores the character number into
[[FONT_CHARNUM]] and the charset into [[FONT_CHARSET]], then calls
[[PRINT_FONTCHAR_AT_TEXT_POS]] to render it.

<<defines>>=
FONT_CHARNUM        EQU     $5A0E   ; font character number to render
FONT_CHARSET        EQU     $5A0F   ; font charset index (1-5)
@ %def FONT_CHARNUM FONT_CHARSET

<<draw border char>>=
    ORG     $5CEC
DRAW_BORDER_CHAR:

    STX     TEXT_COL
    STA     FONT_CHARNUM
    LDY     #$03
    STY     TEXT_ROW
    STOB    #$02,FONT_CHARSET
    JMP     PRINT_FONTCHAR_AT_TEXT_POS
@ %def DRAW_BORDER_CHAR
@ [[DRAW_BORDER_LABELS]] draws text labels around the game border.
Three loops iterate over tables of (column, row) pairs, printing a
border pattern string at each position.  It selects HRCG charset~2
before drawing.  The position tables ([[BORDER_POS_HORIZ]],
[[BORDER_POS_VERT_L]], [[BORDER_POS_VERT_R]]) each contain pairs of
column/row bytes.  The pattern strings ([[BORDER_STR_HORIZ]],
[[BORDER_STR_VERT_L]], [[BORDER_STR_VERT_R]]) are printed at each
position via [[PRINT_STRING_ADDR]] ([[$BC/$BD]]).  [[BORDER_LOOP_CTR]]
is a RAM counter used to track the loop iteration.

<<zero page defines>>=
PRINT_STRING_ADDR       EQU     $BC     ; print string source pointer (2 bytes)
@ %def PRINT_STRING_ADDR

<<defines>>=
BORDER_STR_VERT_L      EQU     $5EC1   ; vertical border pattern string (left)
BORDER_STR_VERT_R      EQU     $5EC4   ; vertical border pattern string (right)
BORDER_LOOP_CTR        EQU     $5DC3   ; loop counter for border label drawing
@ %def BORDER_STR_VERT_L BORDER_STR_VERT_R BORDER_LOOP_CTR

@ Border label position tables, used by [[DRAW_BORDER_LABELS]] to
place text labels around the game map border.

<<border label positions>>=
    ORG     $5E7B
BORDER_POS_HORIZ:                     ; 6 col/row pairs for horizontal labels
    DC.B    $01,$09,$01,$0E,$01,$13
    DC.B    $16,$09,$16,$0E,$16,$13
BORDER_POS_VERT_L:                    ; 10 col/row pairs for vertical labels (left)
    DC.B    $01,$0A,$01,$0B,$01,$0C,$01,$0D
    DC.B    $01,$0F,$01,$12
    DC.B    $16,$0A,$16,$0D,$16,$0F,$16,$12
BORDER_POS_VERT_R:                    ; 10 col/row pairs for vertical labels (right)
    DC.B    $10,$0A,$10,$0D,$10,$0F,$10,$12
    DC.B    $25,$0A,$25,$0D,$25,$0F
    DC.B    $25,$10,$25,$11,$25,$12
@ %def BORDER_POS_HORIZ BORDER_POS_VERT_L BORDER_POS_VERT_R

@ The horizontal border frame pattern string, printed repeatedly by
[[DRAW_BORDER_LABELS]] along the top and bottom edges of the map.

<<border frame pattern>>=
    ORG     $5EAF
BORDER_STR_HORIZ:
    DC.B    $11               ; length = 17
    HEX     F0 F1 F0 F1 F0 F1 F0 F1
    HEX     F0 F1 F0 F1 F0 F1 F0 F1
    DC.B    $F0,$02,$F0,$F1,$02,$F1,$F0
@ %def BORDER_STR_HORIZ

<<draw border labels>>=
    ORG     $5CFD
DRAW_BORDER_LABELS:
    SUBROUTINE DRAW_BORDER_LABELS

    ; Select HRCG charset 2
    LDA     #$81 ; ctrl-A
    JSR     ROM_COUT1
    LDA     #$B2 ; '2' = charset 2
    JSR     ROM_COUT1

    ; Loop 1: horizontal borders (6 positions from BORDER_POS_HORIZ)
    LDX     #$0A ; index 10 (5 pairs, counting down by 2)
    STX     BORDER_LOOP_CTR
    stow    BORDER_STR_HORIZ,PRINT_STRING_ADDR
.loop1:
    LDA     BORDER_POS_HORIZ,X
    STA     TEXT_COL
    INX
    LDA     BORDER_POS_HORIZ,X
    STA     TEXT_ROW
    JSR     PRINT_STRING
    DEC     BORDER_LOOP_CTR
    DEC     BORDER_LOOP_CTR
    LDX     BORDER_LOOP_CTR
    BPL     .loop1

    ; Loop 2: vertical borders left (10 positions from BORDER_POS_VERT_L)
    LDX     #$12 ; index 18 (9 pairs, counting down by 2)
    STX     BORDER_LOOP_CTR
    stow    BORDER_STR_VERT_L,PRINT_STRING_ADDR
.loop2:
    LDA     BORDER_POS_VERT_L,X
    STA     TEXT_COL
    INX
    LDA     BORDER_POS_VERT_L,X
    STA     TEXT_ROW
    JSR     PRINT_STRING
    DEC     BORDER_LOOP_CTR
    DEC     BORDER_LOOP_CTR
    LDX     BORDER_LOOP_CTR
    BPL     .loop2

    ; Loop 3: vertical borders right (10 positions from BORDER_POS_VERT_R)
    LDX     #$12
    STX     BORDER_LOOP_CTR
    stow    BORDER_STR_VERT_R,PRINT_STRING_ADDR
.loop3:
    LDA     BORDER_POS_VERT_R,X
    STA     TEXT_COL
    INX
    LDA     BORDER_POS_VERT_R,X
    STA     TEXT_ROW
    JSR     PRINT_STRING
    DEC     BORDER_LOOP_CTR
    DEC     BORDER_LOOP_CTR
    LDX     BORDER_LOOP_CTR
    BPL     .loop3
    RTS
@ %def DRAW_BORDER_LABELS
Plots six decorative 2$\times$2 font characters at fixed positions
around the game border using [[PLOT_CHAR]].

<<draw border icons>>=
    ORG     $5D7A
DRAW_BORDER_ICONS:

    LDA     #$02 ; char 2 at col 4, row 11
    LDX     #$04
    LDY     #$0B
    JSR     PLOT_CHAR

    LDA     #$01 ; char 1 at col 4, row 16
    LDX     #$04
    LDY     #$10
    JSR     PLOT_CHAR

    LDA     #$03 ; char 3 at col 34, row 16
    LDX     #$22
    LDY     #$10
    JSR     PLOT_CHAR

    LDA     #$04 ; char 4 at col 34, row 11
    LDX     #$22
    LDY     #$0B
    JSR     PLOT_CHAR

    LDA     #$1C ; char 28 at col 16, row 16
    LDX     #$10
    LDY     #$10
    JSR     PLOT_CHAR

    LDA     #$1C ; char 28 at col 22, row 11
    LDX     #$16
    LDY     #$0B
    JMP     PLOT_CHAR
@ %def DRAW_BORDER_ICONS


@ Border display data at [[$5DBF]]--[[$5F18]].  The border animation
cycles through positions in [[BORDER_POS_TABLE]], drawing icons at
each map border cell.  The 3-byte records are (icon, column, row):
icon=\$00 draws the default border glyph; nonzero icons draw special
decorations (e.g.\ doors, markers).


@ The UI text stream is a concatenated display string parsed by
